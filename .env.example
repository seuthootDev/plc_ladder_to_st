# Gemini API (https://aistudio.google.com/apikey)
# Copy this file to .env and set your key:
#   copy .env.example .env
GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Retry / pacing (defaults wait until all programs succeed)
# GEMINI_RETRY_MAX=0          # 0 = unlimited retries on 503/429 etc.
# GEMINI_RETRY_BASE_DELAY=10  # first wait seconds
# GEMINI_RETRY_MAX_DELAY=120  # max wait between retries
# GEMINI_REQUEST_DELAY=3      # pause between programs
